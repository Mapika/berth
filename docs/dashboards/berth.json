{
  "title": "berth cluster",
  "schemaVersion": 38,
  "version": 1,
  "tags": ["berth", "inference", "cluster"],
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "GPU utilization",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "berth_node_gpu_util_pct",
          "legendFormat": "{{node}} gpu{{gpu}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100 }
      }
    },
    {
      "id": 2,
      "title": "GPU memory used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "berth_node_gpu_mem_used_bytes",
          "legendFormat": "{{node}} gpu{{gpu}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "id": 3,
      "title": "In-flight requests by deployment",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "berth_deployment_in_flight",
          "legendFormat": "{{node}} {{model}} (dep {{deployment}})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "p95 latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "berth_deployment_latency_p95_ms",
          "legendFormat": "{{node}} {{model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      }
    },
    {
      "id": 5,
      "title": "Request rate (last window)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum by (node) (berth_deployment_requests_total)",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Error rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rate(berth_deployment_errors_total[1m])",
          "legendFormat": "{{node}} {{model}}",
          "refId": "A"
        }
      ]
    }
  ]
}
